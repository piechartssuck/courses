stroke = 0.5) +
geom_boxplot(alpha = 0.3,
show.legend = FALSE) +
scale_fill_manual(values=c("#5C9AC5","#82BD4E","#EE6A64")) +
theme_void() +
theme_ipsum(axis_text_size = 0,
axis_title_size = 0,
plot_title_size = 0,
subtitle_size = 0,
strip_text_size = 0)
penguins_plot
